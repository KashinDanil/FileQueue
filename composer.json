{
    "name": "danil-kashin/file-queue",
    "description": "A simple, file-based FIFO queue that keeps messages in order across restarts.",
    "type": "library",
    "license": "BSD-3-Clause",
    "require": {
        "php": ">=8.1",
        "ext-json": "*",
        "danil-kashin/file-lock": "^1.0",
        "danil-kashin/worker": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "ext-posix": "*"
    },
    "autoload": {
        "psr-4": {
            "DanilKashin\\FileQueue\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DanilKashin\\FileQueue\\Tests\\": "tests/"
        }
    }
}
